# ────────────────────────────────────────────────────────────────────────────
# FORKFUL — Complete Environment Configuration
# Copy this to .env and fill in your actual values
# ────────────────────────────────────────────────────────────────────────────

# General
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:80
VITE_SOCKET_URL=http://localhost:80

# Database
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_URL=mongodb://admin:admin@localhost:27017/forkful?authSource=admin

# Redis (for Socket.io adapter and caching)
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBIT_USER=guest
RABBIT_PASS=guest
RABBIT_URL=amqp://guest:guest@localhost:5672

# Authentication
JWT_SEC=your-super-secret-jwt-key-change-this-in-production
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
ADMIN_ACCESS_CODE=admin123

# Payment
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_SECRET=your-razorpay-secret
STRIPE_SECRET_KEY=your-stripe-secret-key
INTERNAL_SERVICE_KEY=your-internal-service-key-here

# AI/ML (Anthropic Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google Maps (optional, not used in current implementation)
GOOGLE_MAPS_API_KEY=your-google-maps-key

# Port configurations (for local development)
AUTH_PORT=5001
RESTAURANT_PORT=5002
RIDER_PORT=5003
ADMIN_PORT=5004
UTILS_PORT=5005
REALTIME_PORT=5006

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@forkful.app

# Twilio (for SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890
