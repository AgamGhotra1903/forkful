# Docker environment variables
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:80
VITE_SOCKET_URL=http://localhost:80

MONGO_USER=admin
MONGO_PASSWORD=admin
RABBIT_USER=guest
RABBIT_PASS=guest
JWT_SEC=your-super-secret-jwt-key-change-this-in-production

ANTHROPIC_API_KEY=your-anthropic-api-key

# These will be set by docker-compose networking
MONGO_URL=mongodb://admin:admin@mongodb:27017/forkful?authSource=admin
RABBIT_URL=amqp://guest:guest@rabbitmq:5672
REDIS_URL=redis://redis:6379
